{
  "compilerOptions": {
    "allowJs": true,
    "baseUrl": ".",
    "checkJs": false,
    "jsx": "preserve",
    "moduleResolution": "bundler",
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": ["app/**/*.js", "app/**/*.jsx", "components/**/*.js", "components/**/*.jsx", "data/**/*.js"],
  "exclude": ["node_modules"]
}
